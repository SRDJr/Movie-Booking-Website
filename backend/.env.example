# MongoDB Database Connection
# Format: mongodb+srv://username:password@cluster.mongodb.net/database_name
MONGO_URI=mongodb+srv://user:password@cluster.mongodb.net/movie_db

# JWT Configuration
# Use a strong secret key (min 32 chars recommended)
JWT_SECRET=your_jwt_secret_key_here_change_in_production

# Admin Registration Secret
# Required when registering a new admin user
ADMIN_SECRET=admin_secret_key_for_registration

# TMDB API Configuration
# Get your API key from https://www.themoviedb.org/settings/api
TMDB_API_KEY=your_tmdb_api_key_here

# Payment Gateway Configuration (Razorpay)
RAZORPAY_KEY_ID=your_razorpay_id
RAZORPAY_KEY_SECRET=your_razorpay_secret_key

# Server Configuration
PORT=5000
NODE_ENV=development
